#!/bin/bash

BASE_DIR="$HOME/ssh-manager"
KEY_DIR="$BASE_DIR/keys"
KEY_FILE="$KEY_DIR/id_ed25519"
HOST_DB="$BASE_DIR/hosts.json"
SSH_CONFIG="$HOME/.ssh/config"
BACKUP_DIR="$BASE_DIR/backups"

mkdir -p "$KEY_DIR" "$BACKUP_DIR" "$HOME/.ssh"

# ----------------------------
# Generate Key
# ----------------------------
generate_key() {
    if [ ! -f "$KEY_FILE" ]; then
        echo "Generating SSH key..."
        ssh-keygen -t ed25519 -f "$KEY_FILE" -N ""
    fi
}

# ----------------------------
# Init DB
# ----------------------------
init_db() {
    if [ ! -f "$HOST_DB" ]; then
        echo "[]" > "$HOST_DB"
    fi
}

# ----------------------------
# Get Fingerprint
# ----------------------------
get_fingerprint() {
    ssh-keygen -lf "$KEY_FILE.pub" | awk '{print $2}'
}

# ----------------------------
# Add Multiple Hosts
# ----------------------------
add_hosts() {
    read -p "Group name: " GROUP
    read -p "Username: " USER
    read -p "Enter hosts (space separated): " HOSTS

    FP=$(get_fingerprint)

    for HOST in $HOSTS; do
        read -p "Alias for $HOST: " ALIAS

        echo "[<3]Installing key on $HOST..."
        ssh-copy-id -i "$KEY_FILE.pub" "$USER@$HOST"

        TMP=$(mktemp)
        jq ". += [{
            \"alias\":\"$ALIAS\",
            \"host\":\"$HOST\",
            \"user\":\"$USER\",
            \"group\":\"$GROUP\",
            \"fingerprint\":\"$FP\"
        }]" "$HOST_DB" > "$TMP" && mv "$TMP" "$HOST_DB"

        echo "Added $ALIAS"
    done

    rebuild_config
}
Echo "-------------------------------------------------"
# ----------------------------
# Rebuild SSH Config
# ----------------------------
rebuild_config() {
    echo "Rebuilding SSH config..."
    echo "" > "$SSH_CONFIG"

    jq -r '.[] |
    "Host \(.alias)
    HostName \(.host)
    User \(.user)
    IdentityFile '"$KEY_FILE"'
"' "$HOST_DB" >> "$SSH_CONFIG"
}
Echo "--------------------------------------------"
# ----------------------------
# List Hosts
# ----------------------------
list_hosts() {
    jq -r '.[] | "\(.alias) [\(.group)] -> \(.user)@\(.host)"' "$HOST_DB"
}

# ----------------------------
# ----------------------------
# Interactive Menu
# ----------------------------
interactive_menu() {
    init_db
    generate_key

    if [ ! -s "$HOST_DB" ] || [ "$(jq length "$HOST_DB")" -eq 0 ]; then
        echo "No hosts configured."
        return
    fi

    selection=$(jq -r '.[] | "\(.alias) [\(.group)] -> \(.user)@\(.host)"' "$HOST_DB" \
        | fzf --height=40% \
              --border \
              --prompt="Select SSH Host > " \
              --preview-window=right:40% \
              --preview="echo {}")

    if [ -z "$selection" ]; then
        return
    fi

    alias=$(echo "$selection" | awk '{print $1}')

    echo "Connecting to $alias..."
    ssh "$alias"
}
# ----------------------------
# Backup System
# ----------------------------
backup_all() {
    TS=$(date +%Y%m%d-%H%M%S)
    DEST="$BACKUP_DIR/backup-$TS"
    mkdir -p "$DEST"

    cp -r "$KEY_DIR" "$DEST/"
    cp "$HOST_DB" "$DEST/"
    cp "$SSH_CONFIG" "$DEST/"

    echo "Backup created at $DEST"
}

# ----------------------------
# Restore Backup
# ----------------------------
restore_backup() {
    read -p "Path to backup folder: " PATH_RESTORE

    cp -r "$PATH_RESTORE/keys" "$BASE_DIR/"
    cp "$PATH_RESTORE/hosts.json" "$HOST_DB"
    cp "$PATH_RESTORE/config" "$SSH_CONFIG" 2>/dev/null || true

    rebuild_config
    echo "Restore complete."
}
# ----------------------------
# Main
# ----------------------------
case "$1" in
    add)
        generate_key
        init_db
        add_hosts
        ;;
    list)
        list_hosts
        ;;
    group)
        list_group
        ;;
    rebuild)
        rebuild_config
        ;;
    backup)
        backup_all
        ;;
    restore)
        restore_backup
        ;;
    *)
        ;;
esac
# ----------------------------
# Main Menu
# ----------------------------
main_menu() {
    while true; do
        choice=$(printf "Connect\nAdd Hosts\nList Hosts\nRebuild Config\nExit" \
            | fzf --height=40% --border --prompt="SSH Manager > ")

        case "$choice" in
            "Connect")
                interactive_menu
                ;;
            "Add Hosts")
                add_hosts
                ;;
            "List Hosts")
                list_hosts
                read -p "Press Enter to continue..."
                ;;
            "Rebuild Config")
                rebuild_config
                ;;
            "Exit")
                exit 0
                ;;
        esac
    done
}

main_menu

