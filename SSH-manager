# -----------------------
# Generate SSH Key
# -----------------------

generate_key() {

if [ ! -f "$KEY_FILE" ]
then
echo "${BLUE}Generating SSH key...${RESET}"
ssh-keygen -t ed25519 -f "$KEY_FILE" -N ""
fi

}

# -----------------------
# Group Menu
# -----------------------

group_menu() {

GROUP=$(jq -r '.[].group' "$HOST_DB" | sort -u | \
fzf --border --height=40% --prompt="Group > ")

[ -z "$GROUP" ] && return

host_menu "$GROUP"

}

# -----------------------
# Host Menu
# -----------------------

host_menu() {

GROUP="$1"

HOST=$(jq -r ".[] | select(.group==\"$GROUP\") |
\"\(.alias)|\(.user)|\(.host)|\(.fingerprint)\"" "$HOST_DB" | \
fzf \
--delimiter="|" \
--with-nth=1,2,3 \
--border \
--height=70% \
--prompt="$GROUP > " \
--preview '

alias=$(echo {} | cut -d "|" -f1)
user=$(echo {} | cut -d "|" -f2)
host=$(echo {} | cut -d "|" -f3)
fp=$(echo {} | cut -d "|" -f4)

echo "Host Information"
echo "----------------"
echo ""
echo "Alias : $alias"
echo "User  : $user"
echo "Host  : $host"
echo ""
echo "Fingerprint"
echo "$fp"
echo ""

ping -c1 -W1 $host >/dev/null 2>&1 \
&& echo "Host reachable" \
|| echo "Host unreachable"

' \
--preview-window=right:50%)

[ -z "$HOST" ] && return

ALIAS=$(echo "$HOST" | cut -d "|" -f1)

action_menu "$ALIAS"

}

# -----------------------
# Action Menu
# -----------------------

action_menu() {

ALIAS="$1"

ACTION=$(printf "Connect\nReinstall Key\nDelete Host\nView JSON\nBack" | \
fzf --border --prompt="$ALIAS > ")

case "$ACTION" in

Connect)

ssh "$ALIAS"
;;

Reinstall\ Key)

USER=$(jq -r ".[] | select(.alias==\"$ALIAS\") | .user" "$HOST_DB")
HOST=$(jq -r ".[] | select(.alias==\"$ALIAS\") | .host" "$HOST_DB")

ssh-copy-id -i "$KEY_FILE.pub" "$USER@$HOST"
;;

Delete\ Host)

TMP=$(mktemp)

jq "del(.[] | select(.alias==\"$ALIAS\"))" "$HOST_DB" > "$TMP"

mv "$TMP" "$HOST_DB"
;;

View\ JSON)

jq ".[] | select(.alias==\"$ALIAS\")" "$HOST_DB" | bat --language=json
;;

*)

return
;;

esac

}

# -----------------------
# Add Hosts
# -----------------------

add_hosts() {

read -p "Group: " GROUP
read -p "User: " USER
read -p "Hosts (space separated): " HOSTS

for HOST in $HOSTS
do

read -p "Alias for $HOST: " ALIAS

ssh-copy-id -f -i "$KEY_FILE.pub" "$USER@$HOST"

TMP=$(mktemp)

jq ". += [{
\"alias\":\"$ALIAS\",
\"host\":\"$HOST\",
\"user\":\"$USER\",
\"group\":\"$GROUP\",
\"fingerprint\":\"local\"
}]" "$HOST_DB" > "$TMP"

mv "$TMP" "$HOST_DB"

done

}

# -----------------------
# Dashboard
# -----------------------

dashboard() {

banner

while true
do

CHOICE=$(printf "Browse Fleet\nAdd Hosts\nExit" | \
fzf --border --height=40% --prompt="EasySSH > ")

case "$CHOICE" in

Browse\ Fleet)

group_menu
;;

Add\ Hosts)

add_hosts
;;

Exit)

exit
;;

esac

done

}

generate_key
dashboard
